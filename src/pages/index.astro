---
import Layout from '../layouts/Layout.astro';

const title = 'lyp';
const description = 'OS爱好者的记录';
---

<Layout title={title}>
	<main>
		<div class="hero">
			<div class="avatar">🍙</div>
			<h1>{title}</h1>
			<p class="subtitle">{description}</p>
			<p class="intro">记录学习 xv6、CS144、系统编程的过程</p>
		</div>
		
		<section class="links">
			<a href="/posts" class="link-card">
				<span class="icon">📝</span>
				<span>文章列表</span>
			</a>
			<a href="https://github.com" class="link-card" target="_blank">
				<span class="icon">💻</span>
				<span>GitHub</span>
			</a>
		</section>
	</main>
</Layout>

<style>
	main {
		max-width: 700px;
		margin: 0 auto;
		padding: 3rem 2rem;
		min-height: 100vh;
	}

	.hero {
		text-align: center;
		padding: 2rem 0 3rem;
	}

	.avatar {
		width: 80px;
		height: 80px;
		margin: 0 auto 1.5rem;
		background: #2a2a2a;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 3rem;
		border: 2px solid #404040;
	}

	h1 {
		font-size: 2.5rem;
		margin: 0;
		color: #ffffff;
		font-weight: 700;
	}

	.subtitle {
		font-size: 1.2rem;
		color: #999999;
		margin: 0.5rem 0;
	}

	.intro {
		color: #666666;
		margin-top: 1rem;
		font-size: 0.95rem;
	}

	.links {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1rem;
		margin-top: 2rem;
	}

	.link-card {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1.5rem;
		background: #2a2a2a;
		border: 1px solid #404040;
		border-radius: 8px;
		text-decoration: none;
		color: #e5e5e5;
		transition: all 0.3s;
	}

	.link-card:hover {
		background: #333333;
		border-color: #555555;
		transform: translateY(-2px);
	}

	.icon {
		font-size: 1.5rem;
	}
</style>
