---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('posts');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - lyp`}>
	<main>
		<article class="post">
			<header>
				<h1>{post.data.title}</h1>
				<div class="meta">
					<time>{post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
					{post.data.tags && post.data.tags.length > 0 && (
						<div class="tags">
							{post.data.tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					)}
				</div>
			</header>
			<div class="content">
				<Content />
			</div>
		</article>
		<nav class="post-nav">
			<a href="/posts" class="back-link">← 返回文章列表</a>
		</nav>
	</main>
</Layout>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem;
		min-height: 100vh;
	}

	.post {
		background: #1e293b;
		border: 1px solid #334155;
		border-radius: 12px;
		padding: 2.5rem;
	}

	header {
		margin-bottom: 2.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid #334155;
	}

	h1 {
		font-size: 2.5rem;
		margin: 0 0 1rem 0;
		color: #f1f5f9;
		font-weight: 700;
		line-height: 1.3;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	time {
		color: #64748b;
		font-size: 0.95rem;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.tag {
		font-size: 0.85rem;
		padding: 0.3rem 0.8rem;
		background: #334155;
		border-radius: 6px;
		color: #94a3b8;
	}

	.content {
		line-height: 1.8;
		color: #cbd5e1;
		font-size: 1.05rem;
	}

	.content :global(h1),
	.content :global(h2),
	.content :global(h3),
	.content :global(h4) {
		color: #f1f5f9;
		font-weight: 600;
		margin-top: 2rem;
		margin-bottom: 1rem;
	}

	.content :global(h1) {
		font-size: 2rem;
		border-bottom: 2px solid #334155;
		padding-bottom: 0.5rem;
	}

	.content :global(h2) {
		font-size: 1.6rem;
	}

	.content :global(h3) {
		font-size: 1.3rem;
	}

	.content :global(p) {
		margin: 1.2rem 0;
	}

	.content :global(a) {
		color: #60a5fa;
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s;
	}

	.content :global(a:hover) {
		border-bottom-color: #60a5fa;
	}

	.content :global(code) {
		background: #0f172a;
		padding: 0.2rem 0.5rem;
		border-radius: 4px;
		font-family: 'Fira Code', 'Courier New', monospace;
		font-size: 0.9em;
		color: #e879f9;
		border: 1px solid #334155;
	}

	.content :global(pre) {
		background: #0f172a;
		border: 1px solid #334155;
		padding: 1.5rem;
		border-radius: 8px;
		overflow-x: auto;
		margin: 1.5rem 0;
	}

	.content :global(pre code) {
		background: none;
		padding: 0;
		border: none;
		color: #e2e8f0;
	}

	.content :global(blockquote) {
		border-left: 4px solid #475569;
		padding-left: 1.5rem;
		margin: 1.5rem 0;
		color: #94a3b8;
		font-style: italic;
	}

	.content :global(ul),
	.content :global(ol) {
		padding-left: 1.5rem;
		margin: 1rem 0;
	}

	.content :global(li) {
		margin: 0.5rem 0;
	}

	.content :global(img) {
		max-width: 100%;
		border-radius: 8px;
		margin: 1.5rem 0;
	}

	.post-nav {
		margin-top: 2rem;
	}

	.back-link {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: #1e293b;
		border: 1px solid #334155;
		border-radius: 8px;
		color: #94a3b8;
		text-decoration: none;
		transition: all 0.3s;
	}

	.back-link:hover {
		background: #334155;
		color: #f1f5f9;
	}

	@media (max-width: 768px) {
		.post {
			padding: 1.5rem;
		}

		h1 {
			font-size: 2rem;
		}
	}
</style>
