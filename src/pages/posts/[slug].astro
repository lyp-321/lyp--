---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('posts');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - lyp`}>
	<main>
		<article class="post">
			<header>
				<h1>{post.data.title}</h1>
				<div class="meta">
					<time>{post.data.date.toLocaleDateString('zh-CN')}</time>
					{post.data.tags && (
						<div class="tags">
							{post.data.tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					)}
				</div>
			</header>
			<div class="content">
				<Content />
			</div>
		</article>
		<a href="/posts" class="back-link">← 返回文章列表</a>
	</main>
</Layout>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem;
	}

	.post header {
		margin-bottom: 2rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid #eee;
	}

	h1 {
		font-size: 2.5rem;
		margin: 0 0 1rem 0;
		color: #333;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		color: #666;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
	}

	.tag {
		font-size: 0.85rem;
		padding: 0.25rem 0.75rem;
		background: #e5e7eb;
		border-radius: 4px;
		color: #4b5563;
	}

	.content {
		line-height: 1.8;
		color: #333;
	}

	.content :global(h2) {
		font-size: 1.8rem;
		margin: 2rem 0 1rem;
		color: #333;
	}

	.content :global(h3) {
		font-size: 1.4rem;
		margin: 1.5rem 0 0.75rem;
		color: #333;
	}

	.content :global(p) {
		margin: 1rem 0;
	}

	.content :global(code) {
		background: #f5f5f5;
		padding: 0.2rem 0.4rem;
		border-radius: 3px;
		font-family: 'Courier New', monospace;
		font-size: 0.9em;
	}

	.content :global(pre) {
		background: #1e1e1e;
		color: #d4d4d4;
		padding: 1rem;
		border-radius: 6px;
		overflow-x: auto;
		margin: 1.5rem 0;
	}

	.content :global(pre code) {
		background: none;
		padding: 0;
		color: inherit;
	}

	.back-link {
		display: inline-block;
		margin-top: 3rem;
		color: #2563eb;
		text-decoration: none;
	}

	.back-link:hover {
		text-decoration: underline;
	}
</style>
